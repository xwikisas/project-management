    <property>
      <code>require(['jquery', 'xwiki-selectize'], function($) {
  let select = $('#openproject-dashboard-project-select');
  if (!select.length) {
    return;
  }

  function getConnection() {
    let connSelect = $('#openproject-dashboard-connection-select');
    return connSelect.length ? connSelect.val() : select.attr('data-connection');
  }

  function initSelectize(connection) {
    if (select[0].selectize) {
      select[0].selectize.destroy();
    }
    let projectsREST = XWiki.contextPath + '/rest/wikis/' + XWiki.currentWiki +
        '/openproject/instance/' + encodeURIComponent(connection) + '/suggest/projects';
    select.xwikiSelectize({
      maxItems: 1,
      create: false,
      placeholder: select.attr('data-placeholder'),
      load: function(text, callback) {
        $.getJSON(projectsREST, { search: text, selectedItem: select.val() })
          .done(function(results) {
          $('#openproject-dashboard-invalid-connection').addClass('hidden');
          callback(results);
        })
          .fail(function(err) {
          if (err &amp;&amp; err.status === 404) {
            $('#openproject-dashboard-invalid-connection').removeClass('hidden');
          }
          callback([]);
        });
      }
    });
  }

  let currentConnection = getConnection();
  if (currentConnection) {
    initSelectize(currentConnection);
  }

  $('#openproject-dashboard-connection-select').on('change', function() {
    let newConnection = $(this).val();
    if (!newConnection || newConnection === currentConnection) {
      return;
    }
    currentConnection = newConnection;
    initSelectize(newConnection);
  });

  select.on('change', function() {
    let value = select.val();
    if (!value) {
      return;
    }
    let label = value;
    let selectize = select[0].selectize;
    if (selectize &amp;&amp; selectize.options[value]) {
      label = selectize.options[value].label || selectize.options[value].text || value;
    }
    $('#openproject-dashboard-project-label-input').val(label);
    $('#openproject-dashboard-project-form').submit();
  });
});</code>
