  <hidden>true</hidden>
  <content>{{velocity}}
#set ($configClass = 'OpenProject.Code.DashboardConnectionConfigClass')
#set ($configObj = $doc.getObject($configClass))
#if($request.method == 'POST' &amp;&amp; $request.action == 'saveConnection' &amp;&amp; $services.csrf.isTokenValid($request.csrf_token))
  #set ($discard = $configObj.set('selectedConnection', $request.connection))
  #set ($discard = $doc.save('Updated connection', true))
  $response.sendRedirect($doc.getURL())
  #stop
#end
#set ($connectionOptions = $services.openproject.getConnectionOptions())
{{html clean="false"}}
&lt;div class="form-group"&gt;
#set ($selectedConnection = '')
#if($configObj)
  #set ($selectedConnection = $configObj.getValue('selectedConnection'))
#end
#if ($connectionOptions.size() == 0)
 &lt;div class="box warningmessage"&gt;
    &lt;p&gt;$escapetool.xml($services.localization.render('openproject.dashboard.selectConnection.noConnections'))&lt;/p&gt;
  &lt;/div&gt;

#elseif ($connectionOptions.size() == 1)
  #set ($singleConnectionName = $connectionOptions.get(0).name)
  #if(!$selectedConnection || !$singleConnectionName.equals($selectedConnection))
    #set ($discard = $configObj.set('selectedConnection', $singleConnectionName))
    #set ($discard = $doc.save('Updated connection', true))
    $response.sendRedirect($doc.getURL())
  #end
  &lt;div class="box infomessage"&gt;
    &lt;p&gt;
      &lt;strong&gt;
        $escapetool.xml($services.localization.render('openproject.dashboard.singleConnection.connectionInfo', $escapetool.xml($singleConnectionName)))
      &lt;/strong&gt;
    &lt;/p&gt;
    &lt;p class="text-muted"&gt;$escapetool.xml($services.localization.render('openproject.dashboard.singleConnection.description'))&lt;/p&gt;
  &lt;/div&gt;
#else
  &lt;div class="box infomessage"&gt;
    &lt;p&gt;$escapetool.xml($services.localization.render('openproject.dashboard.multipleConnections.description'))&lt;/p&gt;
  &lt;/div&gt;
    &lt;form id="connectionForm" method="post" class="withLock xform" action=""&gt;
      &lt;label for="openproject-dashboard-connection-select"&gt;$escapetool.xml($services.localization.render('openproject.dashboard.selectConnection.label'))&lt;/label&gt;
      &lt;select id="openproject-dashboard-connection-select" name="connection" class="form-control"&gt;
        &lt;option value="" disabled&gt;$escapetool.xml($services.localization.render('openproject.dashboard.selectConnection.placeholder'))&lt;/option&gt;
        #foreach ($option in $connectionOptions)
        &lt;option value="$option.value" #if($selectedConnection == $option.value) selected #end&gt;$escapetool.xml($option.name)&lt;/option&gt;
        #end
      &lt;/select&gt;
      &lt;input id="openproject-dashboard-form-token" type="hidden" name="csrf_token" value="${escapetool.xml($services.csrf.token)}"/&gt;
      &lt;input type="hidden" name="action" value="saveConnection"/&gt;
    &lt;/form&gt;
#end
&lt;/div&gt;
{{/html}}
#if ($connectionOptions.size() != 0)

{{dashboard/}}
#end
{{/velocity}}</content>
