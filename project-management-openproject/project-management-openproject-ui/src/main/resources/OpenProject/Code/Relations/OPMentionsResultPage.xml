  <parent>WebHome</parent>
  <author>xwiki:XWiki.Admin</author>
  <contentAuthor>xwiki:XWiki.Admin</contentAuthor>
  <version>1.1</version>
  <title/>
  <comment/>
  <minorEdit>false</minorEdit>
  <syntaxId>xwiki/2.1</syntaxId>
  <hidden>true</hidden>
  <content>{{velocity wiki="false"}}
#if($xcontext.action == 'get') ##&amp;&amp; "$!{request.outputSyntax}" == 'plain')
  #set ($offset = $numbertool.toNumber($request.offset).intValue())
  #set ($offset = $offset - 1)
  #if (!$offset || $offset &lt; 0)
    #set ($offset = 0)
  #end
  #if ($request.docRef)
    #set ($pageUniqueId = $services.urlshortener.createShortenedURL($services.model.resolveDocument($request.docRef)))
  #end
  #set ($filter = $services.openproject.filterBuilder.addFilter('identifier', '=', "$!pageUniqueId").build())
  #set ($items = $services.openproject.getMentioningWorkPackages($request.instance, $offset, 10, $filter))
    #if (!$items)
      #set ($items = { 'items': [], 'pageSize': 0, 'totalItems': 0, 'offset': 0 })
      #set ($noEndpoint = true)
    #end
  #set($map = {
    "returnedrows": $items.pageSize,
    "totalrows": $items.totalItems,
    "offset": $items.page
  })
  #set($discard = $map.put('rows', []))
  #foreach ($item in $items.items)
    #set ($indexOfSlash = $item.linkable.location.lastIndexOf('/'))
    #set ($id = "Missing")
    #if ($indexOfSlash &gt;= 0)
      #set ($id = $item.linkable.location.substring($indexOfSlash + 1))
    #end
    #set ($rowItem = {
      'identifier.value': "&lt;a target='_blank' href='${services.openproject.getConnectionUrl($request.instance)}/work_packages/$id/activity'&gt;$id&lt;/a&gt;",
      'summary.value': $item.linkable.value
    })
    #set ($discard = $map.rows.add($rowItem))
  #end
    #if ($noEndpoint)
      #set ($discard = $map.rows.add({
        'summary.value': "&lt;div class='box warningmessage'&gt;$escapetool.xml($services.localization.render('openproject.relations.mentions.noEndpoint'))&lt;/div&gt;",
        'identifier.value': "$services.icon.renderHTML('warning')"
      }))
    #end
  #jsonResponse($map)
#end
{{/velocity}}</content>
</xwikidoc>
