    <property>
      <code>require(['jquery'], function ($) {
  $('.openproj-relation-client-params').each(function () {
    let root = $(this);
    let updateParamsInput = function () {
      let result = {};
      root.find('.openproj-relation-client-params-edit :input').filter((i, e) =&gt; e.attributes['name']).each((i, elem) =&gt; {
        result[elem.attributes['name'].value] = elem.value;
      });
      root.find('dd :input').val(JSON.stringify(result));
    };
    root.find('.openproj-relation-client-params-edit :input').on('change', updateParamsInput);
    root.on('click', '.editableProperty-cancel', function () {
      root.find('.openproj-relation-client-params-edit').addClass('hidden');
    });
    root.on('focus', 'dd :input', function () {
      if (root.find('dd :input').length &lt;= 0) {
        return;
      }
      root.find('.openproj-relation-client-params-edit').removeClass('hidden');
      root.find('dd :input').addClass('hidden');
    });
    if (XWiki.contextaction == 'edit') {
      root.find('.openproj-relation-client-params-edit').removeClass('hidden');
      root.find('dd :input').addClass('hidden');
    }

    root.find('dd').each(function () {
        let valueContainer = $(this);
        if (valueContainer.find(':input').length &gt; 0) {
          return;
        }
        // Callback function to execute when mutations are observed
        const callback = (mutationList, observer) =&gt; {
          observer.disconnect();
          root.find('.openproj-relation-client-params-edit').addClass('hidden');
          valueContainer.addClass('loading');
          // If view mode load information for the ids.
          let clientParamsJSON = valueContainer.text().trim();
          if (!clientParamsJSON || valueContainer.find(':input').length &gt; 0) {
            valueContainer.removeClass('loading');
            observer.observe(valueContainer[0], { childList: true });
            return;
          }
          try {
            let clientParams = JSON.parse(clientParamsJSON);
            let displayValue = "";
            Object.entries(clientParams).forEach(param =&gt; {
              displayValue += `&lt;p&gt;&lt;b&gt;${param[0]}&lt;/b&gt;: ${param[1]}&lt;/p&gt;`;
            });
            valueContainer.html(displayValue);
            $('.proj-manag-relation').data('params', clientParams);
          } catch (e) {
            new XWiki.widgets.Notification('Client params are not a valid JSON.', 'error');
          }
          valueContainer.removeClass('loading');
          observer.observe(valueContainer[0], { childList: true });
        };

        // Create an observer instance linked to the callback function
        const observer = new MutationObserver(callback);

        callback([], observer);

        // Start observing the target node for configured mutations
        // observer.observe(valueContainer[0], { childList: true });
      });
  });

});</code>
