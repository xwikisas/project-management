require(["jquery", "create-work-package-utils", "xwiki-l10n!openproject.editworkpackage"], function ($, createWpUtils, l10n) {

  $(document).ready(function () {
    const baseUrl = `${XWiki.contextPath}/rest/wikis/${XWiki.currentWiki}/openproject/instance/`;
    let currentConnection = null;
    let currentWorkPackageId = null;
    let currentLockVersion = null;

    function resetEditForm() {
      const parentSelect = $("#parent-select-edit-work-package");
      if (parentSelect[0] &amp;&amp; parentSelect[0].selectize) {
        parentSelect[0].selectize.destroy();
      }
      parentSelect.empty();
      $("#parent-select-edit-work-package-container").addClass("hidden");
      $("#edit-dynamic-fields-container").empty().addClass("hidden");
      currentLockVersion = null;
    }

    function buildInputs(options) {
      const container = $("#edit-dynamic-fields-container");
      container.empty().addClass("hidden");
      Object.entries(options).forEach(([key, value]) =&gt; {
        const input = createWpUtils.createInput("wp-" + key, key, "wp-" + key, value);
        container.append(input);
      });
      container.removeClass("hidden");
    }

    function isFormValid() {
      let valid = true;
      $("#edit-dynamic-fields-container")
        .find("input[required], select[required], textarea[required]")
        .each(function () {
        const value = $(this).val();
        if (value === null || String(value).trim() === "") {
          valid = false;
        }
      });
      return valid;
    }

    function openEditModal(workPackageId, connection) {
      resetEditForm();
      currentConnection = connection;
      currentWorkPackageId = workPackageId;
      $("#edit-connection").val(connection);

      const url = `${baseUrl}${connection}/workPackages/${workPackageId}/editForm`;
      $.ajax({ method: "GET", contentType: "application/json", url: url })
        .done(function (options) {
        const { parent, lockVersion, ...formFields } = options;

        currentLockVersion = lockVersion;

        buildInputs(formFields);
        createWpUtils.initParentPicker(
          "#edit-connection",
          "#parent-select-edit-work-package",
          "#parent-select-edit-work-package-container",
          parent,
          baseUrl
        );
        $("#edit-work-package-modal").modal("show");
      })
        .fail(function () {
        createWpUtils.notify(l10n.get("notify.loadError"), "error");
      });
    }

    function submitEditForm() {
      if (!isFormValid()) {
        createWpUtils.notify(l10n.get("notify.fillRequiredFields"), "error");
        return;
      }

      const payload = createWpUtils.buildPayload($("#edit-dynamic-fields-container"));
      payload.lockVersion = currentLockVersion;

      const parent = $("#parent-select-edit-work-package").val();
      if (parent) {
        payload.parent = parent;
      }

      const url = `${baseUrl}${currentConnection}/workPackages/${currentWorkPackageId}/update`;
      $.ajax({ method: "POST", contentType: "application/json", url: url, data: JSON.stringify(payload) })
        .done(function (response) {
        createWpUtils.notify(l10n.get("notify.success"), "done");
        $("#edit-work-package-modal").modal("hide");
        document.dispatchEvent(new CustomEvent("op-edit-success", {
          detail: { updatedWp: response, connection: currentConnection }
        }));
      })
        .fail(function (err) {
        if (err.status === 422 &amp;&amp; err.responseJSON) {
          const { parent, lockVersion, validationMessage, ...formFields } = err.responseJSON;
          if (lockVersion !== undefined) {
            currentLockVersion = lockVersion;
          }
          buildInputs(formFields);
          createWpUtils.notify(validationMessage || l10n.get("notify.error"), "error");
          return;
        }
        createWpUtils.notify(l10n.get("notify.error"), "error");
      });
    }

    document.addEventListener("op-edit-requested", function (event) {
      const detail = event.detail || {};
      if (!detail.workPackageId || !detail.connection) {
        return;
      }
      openEditModal(detail.workPackageId, detail.connection);
    });

    $(document).on("submit", "#edit-work-package-form", function (e) {
      e.preventDefault();
      submitEditForm();
    });

    $(document).on("click", "#edit-work-package-cancel-button", function () {
      resetEditForm();
    });
  });
});</code>
