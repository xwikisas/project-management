    <property>
      <cache>long</cache>
    </property>
    <property>
      <code>define(["jquery"], function ($) {
  var pageRelation = null;
  var loadingPromise = null;

  function getRelation() {
    if (pageRelation) {
      return $.Deferred().resolve(pageRelation).promise();
    }

    if (loadingPromise) {
      return loadingPromise;
    }

    let url = XWiki.currentDocument.getRestURL('projectmanagement/relations/client/openproject', 'ancestors=true');
    loadingPromise = $.getJSON(url)
      .then(function (response) {
        pageRelation = response;
        if (!pageRelation.clientParams || pageRelation.clientParams.trim() == '') {
          console.warn('Client parameters are empty.');
          return pageRelation;
        }
        try {
          pageRelation.clientParams = JSON.parse(pageRelation.clientParams);
        } catch (e) {
          console.warn("Failed to parse the client params: " + pageRelation.clientParams);
        }
        return pageRelation;
      })
      .fail(function () {
        pageRelation = {};
      })
      .always(function () {
        loadingPromise = null;
      });

    return loadingPromise;
  }
  if (!pageRelation &amp;&amp; !loadingPromise) {
    getRelation();
  }
  return {
    get: getRelation
  };
});</code>
