    <property>
      <code>require.config({
  paths: {
    'xwiki-propertize': "$services.webjars.url('com.xwiki.commons:xwiki-pro-commons-webjar', 'xwikiPropertize/xwikiPropertize.js')"
  }
});
require(['jquery', 'xwiki-propertize'], function ($) {
  $('.proj-manag-relation-client-params').each(function () {
    let root = $(this);
    root.on('focus', ':input', function () {
      root.find(':input').xwikiPropertize({
        exportMode: "json", // how the data will get serialized. Possible values: "join" or "json".
        addProperty: {
          "label": "add new entry" // The label to be used for the "Add Property" button.
        },
        keyTip: "The key of the entry", // The placeholder for the key input.
        valueTip: "The value of the entry", // The placeholder for the value input.
      });
    });

    root.find('dd').each(function () {
        let valueContainer = $(this);

        // Callback function to execute when mutations are observed
        const callback = (mutationList, observer) =&gt; {
          observer.disconnect();
          valueContainer.toggleClass('loading');
          // If view mode load information for the ids.
          let clientParamsJSON = valueContainer.text().trim();
          if (!clientParamsJSON || valueContainer.find(':input').length &gt; 0) {
            valueContainer.toggleClass('loading');
            observer.observe(valueContainer[0], { childList: true });
            return;
          }
          try {
            let clientParams = JSON.parse(clientParamsJSON);
            let displayValue = "";
            Object.entries(clientParams).forEach(param =&gt; {
              displayValue += `&lt;p&gt;${param[0]} -&gt; ${param[1]}&lt;/p&gt;`;
            });
            valueContainer.html(displayValue);
          } catch (e) {
            new XWiki.widgets.Notification('Client params are not a valid JSON.', 'error');
          }
          valueContainer.toggleClass('loading');
          observer.observe(valueContainer[0], { childList: true });
        };

        // Create an observer instance linked to the callback function
        const observer = new MutationObserver(callback);

        callback([], observer);

        // Start observing the target node for configured mutations
        // observer.observe(valueContainer[0], { childList: true });
      });
  });

});</code>
