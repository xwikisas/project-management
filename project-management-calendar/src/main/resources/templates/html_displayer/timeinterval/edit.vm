## ---------------------------------------------------------------------------
## Time interval displayer: renders two time inputs (min and max) separated by a dash,
## backed by a hidden input storing the combined value as "HH:mm-HH:mm".
## Note: $displayer.value is null for class-based displayers, so the hidden field value
## is set via JavaScript sync from the time inputs instead.
## ---------------------------------------------------------------------------
## Hidden input stores the combined value for the macro parameter.
<input type="hidden" name="$escapetool.xml($displayer.parameters.name)"
  id="$!escapetool.xml($displayer.parameters.id)" class="time-interval-hidden"/>
<div class="time-interval-inputs">
  <input type="time" class="time-interval-min" title="Min time" placeholder="06:00"/>
  <span class="time-interval-separator">–</span>
  <input type="time" class="time-interval-max" title="Max time" placeholder="20:00"/>
</div>
<div class="time-interval-error" style="color: #b94a48; display: none;">
  The minimum time cannot be later than the maximum time.
</div>
<script>
  (function() {
    var hiddenInput = document.querySelector('.time-interval-hidden');
    var minInput = document.querySelector('.time-interval-min');
    var maxInput = document.querySelector('.time-interval-max');
    var errorDiv = document.querySelector('.time-interval-error');

    // On page load, if the hidden field already has a value (e.g., set by XWiki form
    // restoration), populate the time inputs from it.
    function loadFromHidden() {
      var val = hiddenInput.value || '';
      if (val !== '') {
        var parts = val.split('-', 2);
        minInput.value = parts[0] || '';
        maxInput.value = parts.length > 1 ? (parts[1] || '') : '';
      }
    }

    // Validate that min time is not greater than max time.
    function validate() {
      var minVal = minInput.value;
      var maxVal = maxInput.value;
      if (minVal !== '' && maxVal !== '' && minVal > maxVal) {
        errorDiv.style.display = '';
        return false;
      }
      errorDiv.style.display = 'none';
      return true;
    }

    // Sync the hidden field value from the time inputs only when valid.
    function syncHidden() {
      if (!validate()) {
        return;
      }
      var minVal = minInput.value || '';
      var maxVal = maxInput.value || '';
      if (minVal === '' && maxVal === '') {
        hiddenInput.value = '';
      } else {
        hiddenInput.value = minVal + '-' + maxVal;
      }
    }

    // Initial load: populate time inputs from whatever the hidden field holds.
    loadFromHidden();

    // Sync and validate on every relevant event.
    minInput.addEventListener('change', syncHidden);
    maxInput.addEventListener('change', syncHidden);
    minInput.addEventListener('blur', syncHidden);
    maxInput.addEventListener('blur', syncHidden);
  })();
</script>
