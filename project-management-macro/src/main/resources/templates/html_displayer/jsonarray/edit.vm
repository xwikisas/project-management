#set ($discard = $xwiki.jsrx.use('js/projectmanagement/macro/labelsParameter.js', {'minify': false}))
<div class="proj-manag-chart-labels">
  <template id="proj-manag-chart-label-template">
    <div class="proj-manag-chart-label proj-manag-macro-param">
      <div class="proj-manag-header">
        <label>Dataset #n Label..</label>
        <a class="proj-manag-chart-label-remove">$services.icon.renderHTML('trash')</a>
      </div>
      <input type="text" placeholder="Dataset #1">
    </div>
  </template>
</div>
<button class="btn btn-link proj-manag-chart-label-new">Add new label</button>
<textarea id="proj-manag-chart-parameter-labels" class="hidden" value="$!escapetool.xml($!displayer.value)"
  #foreach ($parameter in $displayer.parameters.entrySet())
    $escapetool.xml($parameter.key)="$!escapetool.xml($parameter.value)"
  #end
/>