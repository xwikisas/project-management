#set ($discard = $xwiki.jsrx.use('js/projectmanagement/macro/chartTypeParams.js', {'minify': true}))
<div class="proj-manag-chart-type-params proj-manag-macro-param">
</div>
<template id="proj-manag-chart-type-param-template">
  <div class="proj-manag-chart-type-param">
    <div>
      <div class="proj-manag-chart-type-param-name"></div>
      <div class="proj-manag-chart-type-param-description"></div>
    </div>
    <input type="text" />
  </div>
</template>
<textarea id="proj-manag-chart-type-params" class="hidden" value="$!escapetool.xml($!displayer.value)"
  #foreach ($parameter in $displayer.parameters.entrySet())
    $escapetool.xml($parameter.key)="$!escapetool.xml($parameter.value)"
  #end
/>